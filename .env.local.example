# ── Google Places API ─────────────────────────────────────────────────────────
# https://console.cloud.google.com → Enable "Places API" → Create API Key
# Restrict the key to "Places API" only for security.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Yelp Fusion API ───────────────────────────────────────────────────────────
# https://www.yelp.com/developers/v3/manage_app → Create App → copy API Key
YELP_API_KEY=your_yelp_fusion_api_key_here

# ── Foursquare Places API ─────────────────────────────────────────────────────
# https://location.foursquare.com/developer → Create Project → copy API Key
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# ── Sync endpoint secret ──────────────────────────────────────────────────────
# Arbitrary secret for POST /api/stores/sync — set to any long random string
# e.g.  openssl rand -hex 32
SYNC_SECRET_KEY=your_sync_secret_here
